# ==========================================
# Batch ETL Pipeline Configuration Example
# ==========================================

# PostgreSQL Warehouse Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MinIO (S3-compatible) Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Apache Airflow Settings
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_CONN_POSTGRES_WAREHOUSE=postgresql://postgres:postgres@postgres:5432/warehouse
AIRFLOW_CONN_MINIO_CONN=aws://minioadmin:minioadmin@/?endpoint_url=http%3A%2F%2Fminio%3A9000
